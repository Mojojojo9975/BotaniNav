# .env
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env before running.
# Do NOT commit secrets to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Base URL for the FastAPI backend (no trailing slash)
API_BASE_URL=http://localhost:8000

# Google Maps Android/iOS API key (also set in AndroidManifest & Info.plist)
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_KEY_HERE

# Anthropic API key — used by the Treasure Hunt vision check
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE

# ── Indoor BLE beacon UUIDs ───────────────────────────────────────────────────
# TODO [Backend Phase 3 / Hardware]: Replace placeholder UUIDs with real beacon
# service UUIDs once hardware is provisioned.
BEACON_UUID_GREENHOUSE_A=00000000-0000-0000-0000-000000000001
BEACON_UUID_GREENHOUSE_B=00000000-0000-0000-0000-000000000002
